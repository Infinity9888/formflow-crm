rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== LEADS COLLECTION =====
    // Unauthenticated users CAN create leads (from landing pages)
    // Only authenticated users can read, update, delete leads
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ===== CLIENTS COLLECTION =====
    // Only authenticated users can manage client records
    match /clients/{clientId} {
      allow read, write: if request.auth != null;
    }

    // ===== USERS COLLECTION =====
    // Users can only read/write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ===== DEFAULT: DENY ALL =====
    // Any collection not explicitly listed above is denied
  }
}
